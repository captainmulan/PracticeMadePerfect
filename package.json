{
  "name": "practice-made-perfect",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "sync-deploy-assets": "python scripts/sync_deploy_assets.py",
    "deploy:firebase": "npm run build && npm run sync-deploy-assets && firebase deploy",
    "migrate-tasks": "python scripts/migrate_taskdefs_to_sqlite.py",
    "migrate-db-index": "python scripts/migrate_db_index_columns.py",
    "generate-task-bundle": "python scripts/generate_tasks_bundle.py",
    "rebuild-tasks": "python scripts/migrate_taskdefs_to_sqlite.py && python scripts/generate_tasks_bundle.py"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.17.0",
    "sql.js": "^1.8.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.1"
  }
}
